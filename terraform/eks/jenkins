pipeline {
    agent any

    environment {
        AWS_DEFAULT_REGION = "ap-south-2"
    }

   pipeline {
    agent { label 'linux' }
    tools { git 'LinuxGit' }
    stages {
        stage('Checkout') {
            steps {
                checkout scm
            }
        }
}
}

pipeline {
    agent { label 'windows' }
    tools { git 'WindowsGit' }
    stages {
        stage('Checkout') {
            steps {
                checkout scm
            }
        }
    }
}
        stage('Terraform Init/Plan') {
            steps {
                withCredentials([
                    string(credentialsId: 'AWS_ACCESS_KEY_ID', variable: 'AWS_ACCESS_KEY_ID'),
                    string(credentialsId: 'AWS_SECRET_ACCESS_KEY', variable: 'AWS_SECRET_ACCESS_KEY')
                ]) {
                    dir('terraform/eks') {
                        bat '''
                        terraform init
                        terraform plan -out=tfplan
                        '''
                    }
                }
            }
        }

        stage('Terraform Apply') {
            steps {
                withCredentials([
                    string(credentialsId: 'AWS_ACCESS_KEY_ID', variable: 'AWS_ACCESS_KEY_ID'),
                    string(credentialsId: 'AWS_SECRET_ACCESS_KEY', variable: 'AWS_SECRET_ACCESS_KEY')
                ]) {
                    dir('terraform/eks') {
                        bat 'terraform apply -auto-approve tfplan'
                    }
                }
            }
        }
    }
}
