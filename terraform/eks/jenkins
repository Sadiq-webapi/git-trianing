pipeline {
    agent any

    environment {
        AWS_DEFAULT_REGION = "ap-south-2"
        ECR_REPO = "661268174324.dkr.ecr.ap-south-2.amazonaws.com/git-training"
        CLUSTER_NAME = "clusters"
    }

    stages {
        stage('Checkout') {
            steps {
                git url: 'https://github.com/Sadiq-webapi/git-trianing.git',
                    branch: 'master',
                    credentialsId: 'github-token'
            }
        }

        stage('Terraform Init/Plan') {
            steps {
                // Use the same aws-ecr-creds for Terraform to keep it consistent
                withCredentials([[
                    $class: 'AmazonWebServicesCredentialsBinding', 
                    credentialsId: 'aws-ecr-creds', 
                    accessKeyVariable: 'AWS_ACCESS_KEY_ID', 
                    secretKeyVariable: 'AWS_SECRET_ACCESS_KEY'
                ]]) {
                    dir('terraform/eks') {
                        sh '''
                        terraform init
                        terraform plan -out=tfplan
                        '''
                    }
                }
            }
        }

        stage('Terraform Apply') {
            steps {
                withCredentials([[
                    $class: 'AmazonWebServicesCredentialsBinding', 
                    credentialsId: 'aws-ecr-creds', 
                    accessKeyVariable: 'AWS_ACCESS_KEY_ID', 
                    secretKeyVariable: 'AWS_SECRET_ACCESS_KEY'
                ]]) {
                    dir('terraform/eks') {
                        sh 'terraform apply -auto-approve tfplan'
                    }
                }
            }
        }

        stage('Build & Push to ECR') {
            steps {
                withCredentials([[
                    $class: 'AmazonWebServicesCredentialsBinding', 
                    credentialsId: 'aws-ecr-creds', 
                    accessKeyVariable: 'AWS_ACCESS_KEY_ID', 
                    secretKeyVariable: 'AWS_SECRET_ACCESS_KEY'
                ]]) {
                    sh """
                    # Authenticate Docker to ECR
                    aws ecr get-login-password --region ${AWS_DEFAULT_REGION} | docker login --username AWS --password-stdin 661268174324.dkr.ecr.ap-south-2.amazonaws.com
                    
                    # Build, Tag, and Push
                    docker build -t git-training .
                    docker tag git-training:latest ${ECR_REPO}:latest
                    docker push ${ECR_REPO}:latest
                    """
                }
            }
        }

        stage('Deploy to EKS') {
            steps {
                withCredentials([[
                    $class: 'AmazonWebServicesCredentialsBinding', 
                    credentialsId: 'aws-ecr-creds', 
                    accessKeyVariable: 'AWS_ACCESS_KEY_ID', 
                    secretKeyVariable: 'AWS_SECRET_ACCESS_KEY'
                ]]) {
                    sh """
                    # Update kubeconfig to point to your cluster
                    aws eks update-kubeconfig --region ${AWS_DEFAULT_REGION} --name ${CLUSTER_NAME}
                    
                    # Apply Kubernetes manifests
                    kubectl apply -f deployment.yaml
                    kubectl apply -f service.yaml
                    
                    # Force update if image tag is 'latest'
                    kubectl rollout restart deployment/git-training
                    """
                }
            }
        }
    }
}
