pipeline {
    agent any

    environment {
        AWS_DEFAULT_REGION = "ap-south-2"
        CLUSTER_NAME = "clusters"
    }

    stages {
        stage('Checkout') {
            steps {
                git url: 'https://github.com/Sadiq-webapi/git-trianing.git',
                    branch: 'master',
                    credentialsId: 'github-token'
            }
        }

        stage('Build & Push to Docker Hub') {
            steps {
                // Docker Hub uses Username/Password type
                withCredentials([usernamePassword(credentialsId: 'docker-hub-creds', usernameVariable: 'USER', passwordVariable: 'PASS')]) {
                    bat """
                    docker login -u %USER% -p %PASS%
                    docker build -t mohamedsadiq9741/myapp:%BUILD_NUMBER% .
                    docker tag mohamedsadiq9741/myapp:%BUILD_NUMBER% mohamedsadiq9741/myapp:latest
                    docker push mohamedsadiq9741/myapp:%BUILD_NUMBER%
                    docker push mohamedsadiq9741/myapp:latest
                    """
                }
            }
        }

        stage('Deploy & Load Balancer') {
            steps {
                // CRITICAL: Use the AWS Credentials binding here to avoid the error
                withCredentials([[
                    $class: 'AmazonWebServicesCredentialsBinding', 
                    credentialsId: 'aws-ecr-creds', 
                    accessKeyVariable: 'AWS_ACCESS_KEY_ID', 
                    secretKeyVariable: 'AWS_SECRET_ACCESS_KEY'
                ]]) {
                    bat """
                    @echo off
                    set AWS_ACCESS_KEY_ID=%AWS_ACCESS_KEY_ID%
                    set AWS_SECRET_ACCESS_KEY=%AWS_SECRET_ACCESS_KEY%
                    
                    # Update kubeconfig for Windows
                    aws eks update-kubeconfig --region %AWS_DEFAULT_REGION% --name %CLUSTER_NAME%
                    
                    # Deploy to EKS
                    kubectl apply -f deployment.yaml
                    kubectl apply -f service.yaml
                    
                    # Force a restart to pull the new image
                    kubectl rollout restart deployment/myapp
                    """
                }
            }
        }
    }
}
