pipeline {
    agent any

    environment {
        AWS_DEFAULT_REGION = "ap-south-2"
        // It's better to define these here globally if used in multiple stages
    }

    stages {
        stage('Checkout') {
            steps {
                git url: 'https://github.com/Sadiq-webapi/git-trianing.git',
                    branch: 'master',
                    credentialsId: 'github-token'
            }
        }

        stage('Terraform Init/Plan') {
            steps {
                // Using standard string credentials as you did in your original script
                withCredentials([
                    string(credentialsId: 'AWS_ACCESS_KEY_ID', variable: 'AWS_ACCESS_KEY_ID'),
                    string(credentialsId: 'AWS_SECRET_ACCESS_KEY', variable: 'AWS_SECRET_ACCESS_KEY')
                ]) {
                    dir('terraform/eks') {
                        // Changed 'bat' to 'sh' for Linux
                        sh '''
                        terraform init
                        terraform plan -out=tfplan
                        '''
                    }
                }
            }
        }

        stage('Terraform Apply') {
            steps {
                withCredentials([
                    string(credentialsId: 'AWS_ACCESS_KEY_ID', variable: 'AWS_ACCESS_KEY_ID'),
                    string(credentialsId: 'AWS_SECRET_ACCESS_KEY', variable: 'AWS_SECRET_ACCESS_KEY')
                ]) {
                    dir('terraform/eks') {
                        sh 'terraform apply -auto-approve tfplan'
                    }
                }
            }
        }

     stage('Build & Push to ECR') {
    steps {
        // Use the AWS-specific binding
       // This syntax is specifically for the "AWS Credentials" type
withCredentials([[
    $class: 'AmazonWebServicesCredentialsBinding', 
    credentialsId: 'aws-ecr-creds', 
    accessKeyVariable: 'AWS_ACCESS_KEY_ID', 
    secretKeyVariable: 'AWS_SECRET_ACCESS_KEY'
]]) {
    sh """
    aws ecr get-login-password --region ap-south-2 | docker login --username AWS --password-stdin 661268174324.dkr.ecr.ap-south-2.amazonaws.com
    docker build -t git-training .
    docker tag git-training:latest 661268174324.dkr.ecr.ap-south-2.amazonaws.com/git-training:latest
    docker push 661268174324.dkr.ecr.ap-south-2.amazonaws.com/git-training:latest
    """
}
    }
}
    }
}
