pipeline {
    agent any

    environment {
        AWS_DEFAULT_REGION = "ap-south-2"
    }

    stages {
        stage('Checkout') {
            steps {
                git url: 'https://github.com/Sadiq-webapi/git-trianing.git',
                    branch: 'master',
                    credentialsId: 'github-token'
            }
        }

        stage('Terraform Init/Plan') {
            steps {
                withCredentials([
                    string(credentialsId: 'AWS_ACCESS_KEY_ID', variable: 'AWS_ACCESS_KEY_ID'),
                    string(credentialsId: 'AWS_SECRET_ACCESS_KEY', variable: 'AWS_SECRET_ACCESS_KEY')
                ]) {
                    dir('terraform/eks') {
                        bat '''
                        terraform init
                        terraform plan -out=tfplan
                        '''
                    }
                }
            }
        }

        stage('Terraform Apply') {
            steps {
                withCredentials([
                    string(credentialsId: 'AWS_ACCESS_KEY_ID', variable: 'AWS_ACCESS_KEY_ID'),
                    string(credentialsId: 'AWS_SECRET_ACCESS_KEY', variable: 'AWS_SECRET_ACCESS_KEY')
                ]) {
                    dir('terraform/eks') {
                        bat 'terraform apply -auto-approve tfplan'
                    }
                }
            }
        }
stage('Deploy to EKS') {
    steps {
        // This MUST match the ID you created in the Jenkins UI
        withCredentials([[
            $class: 'AmazonWebServicesCredentialsBinding', 
            credentialsId: 'sadiq-aws', 
            accessKeyVariable: 'AWS_ACCESS_KEY_ID', 
            secretKeyVariable: 'AWS_SECRET_ACCESS_KEY'
        ]]) {
            script {
                // Since you are on Windows, use 'bat' for commands
                bat """
                    @echo off
                    echo "Checking AWS Identity..."
                    aws sts get-caller-identity

                    echo "Updating Kubeconfig for EKS..."
                    aws eks update-kubeconfig --region ap-south-2 --name your-cluster-name

                    echo "Deploying to Kubernetes..."
                    # Use the correct path found by your 'dir' command earlier
                    kubectl apply -f deployment.yaml
                    kubectl apply -f service.yaml
                """
            }
        }
    }
}    
}
}
