pipeline {
    agent any

    environment {
        AWS_DEFAULT_REGION = "ap-south-2"
    }

    stages {
        stage('Checkout') {
            steps {
                git url: 'https://github.com/Sadiq-webapi/git-trianing.git',
                    branch: 'master',
                    credentialsId: 'github-token'
            }
        }

        stage('Terraform Init/Plan') {
            steps {
                withCredentials([
                    string(credentialsId: 'AWS_ACCESS_KEY_ID', variable: 'AWS_ACCESS_KEY_ID'),
                    string(credentialsId: 'AWS_SECRET_ACCESS_KEY', variable: 'AWS_SECRET_ACCESS_KEY')
                ]) {
                    dir('terraform/eks') {
                        bat '''
                        terraform init
                        terraform plan -out=tfplan
                        '''
                    }
                }
            }
        }

        stage('Terraform Apply') {
            steps {
                withCredentials([
                    string(credentialsId: 'AWS_ACCESS_KEY_ID', variable: 'AWS_ACCESS_KEY_ID'),
                    string(credentialsId: 'AWS_SECRET_ACCESS_KEY', variable: 'AWS_SECRET_ACCESS_KEY')
                ]) {
                    dir('terraform/eks') {
                        bat 'terraform apply -auto-approve tfplan'
                    }
                }
            }
        }
stage('Deploy to EKS') {

    steps {

        script {

            // Use 'bat' instead of 'sh' on Windows agents

            bat """

                @echo off

                REM 1. Update EKS config

                aws eks update-kubeconfig --region ap-south-2 --name practice-cluster

                

                REM 2. Use the correct path (change 'eks' to whatever folder 'dir /s' found)

                kubectl apply -f eks/deployment.yaml

                kubectl apply -f eks/service.yaml

            """

        }

    }

}
    }
}
