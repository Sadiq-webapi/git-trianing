pipeline {
    agent none

    environment {
        AWS_DEFAULT_REGION = "ap-south-2"
    }

    stages {
        stage('Checkout on Linux') {
            agent { label 'linux' }
            steps {
                echo "Running on node: ${env.NODE_NAME} (Linux)"
                checkout([$class: 'GitSCM',
                          branches: [[name: '*/main']],
                          userRemoteConfigs: [[url: 'https://github.com/Sadiq-webapi/git-trianing.git',
                                               credentialsId: 'github-token']],
                          gitTool: 'LinuxGit'])
            }
        }

        stage('Checkout on Windows') {
            agent { label 'windows' }
            steps {
                echo "Running on node: ${env.NODE_NAME} (Windows)"
                checkout([$class: 'GitSCM',
                          branches: [[name: '*/main']],
                          userRemoteConfigs: [[url: 'https://github.com/Sadiq-webapi/git-trianing.git',
                                               credentialsId: 'github-token']],
                          gitTool: 'WindowsGit'])
            }
        }

        stage('Terraform Init/Plan') {
            agent { label 'linux' } // Terraform runs best on Linux
            steps {
                echo "Running on node: ${env.NODE_NAME} (Linux)"
                withCredentials([
                    string(credentialsId: 'AWS_ACCESS_KEY_ID', variable: 'AWS_ACCESS_KEY_ID'),
                    string(credentialsId: 'AWS_SECRET_ACCESS_KEY', variable: 'AWS_SECRET_ACCESS_KEY')
                ]) {
                    dir('terraform/eks') {
                        sh '''
                            terraform init
                            terraform plan -out=tfplan
                        '''
                    }
                }
            }
        }

        stage('Terraform Apply') {
            agent { label 'linux' }
            steps {
                echo "Running on node: ${env.NODE_NAME} (Linux)"
                withCredentials([
                    string(credentialsId: 'AWS_ACCESS_KEY_ID', variable: 'AWS_ACCESS_KEY_ID'),
                    string(credentialsId: 'AWS_SECRET_ACCESS_KEY', variable: 'AWS_SECRET_ACCESS_KEY')
                ]) {
                    dir('terraform/eks') {
                        sh 'terraform apply -auto-approve tfplan'
                    }
                }
            }
        }
    }
}
