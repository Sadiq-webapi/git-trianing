pipeline {
    agent any

    environment {
       AWS_ACCESS_KEY_ID     = credentials(' AWS_ACCESS_KEY_ID ')
    AWS_SECRET_ACCESS_KEY = credentials('AWS_SECRET_ACCESS_KEY')
    AWS_DEFAULT_REGION    = "ap-south-2"
    }

    stages {
        stage('Checkout') {
            steps {
                git url: 'https://github.com/Sadiq-webapi/git-trianing.git', branch: 'master', credentialsId: 'github-token'
            }
        }

   stage('Package Lambda') {
    steps {
        bat '"C:\\Program Files\\7-Zip\\7z.exe" a -tzip terraform\\lambda\\lambda_function_payload.zip terraform\\lambda\\index.js'
    }
}



        stage('Terraform Init') {
            steps {
                dir('terraform/lambda') {
                    bat 'terraform init'
                }
            }
        }

        stage('Terraform Plan') {
            steps {
                dir('terraform/lambda') {
                    bat 'terraform plan -out=tfplan'
                }
            }
        }

        stage('Terraform Apply') {
            steps {
                dir('terraform/lambda') {
                    bat 'terraform apply -auto-approve tfplan'
                }
            }
        }
    }
}
