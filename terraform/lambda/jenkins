pipeline {
    agent any

    environment {
        AWS_DEFAULT_REGION = "ap-south-2"
    }

  stages {
        stage('Checkout SCM') {
            steps {
                checkout scm
            }
        }

       stage('Install Terraform') {
    steps {
        bat '''
        curl -fsSL https://releases.hashicorp.com/terraform/1.7.5/terraform_1.7.5_windows_amd64.zip -o terraform.zip
        powershell -Command "Expand-Archive -Path terraform.zip -DestinationPath . -Force"
        move terraform.exe C:\\Windows\\System32\\terraform.exe
        '''
    }
}


        stage('Terraform Init') {
            steps {
                sh 'terraform init'
            }
        }

        stage('Terraform Plan') {
            steps {
                sh 'terraform plan -out=tfplan'
            }
        }
stage('Package Lambda') {
    steps {
        sh '''
        zip -j lambda_function_payload.zip src/index.js
        '''
    }
}

        stage('Terraform Apply') {
            steps {
                sh 'terraform apply -auto-approve tfplan'
            }
        }
    }
}
