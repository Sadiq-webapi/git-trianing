pipeline {
    agent any

    environment {
        AWS_DEFAULT_REGION = "us-east-1"
    }

    stages {
        stage('Checkout') {
            steps {
                git url: 'https://github.com/Sadiq-webapi/git-trianing.git', branch: 'master', credentialsId: 'github-token'
            }
        }

        stage('Install Terraform') {
            steps {
                bat '''
                curl -fsSL https://releases.hashicorp.com/terraform/1.7.5/terraform_1.7.5_windows_amd64.zip -o terraform.zip
                powershell -Command "Expand-Archive -Path terraform.zip -DestinationPath . -Force"
                set PATH=%PATH%;%CD%
                '''
            }
        }

        stage('Terraform Init') {
            steps {
                bat 'terraform init'
            }
        }

        stage('Terraform Plan') {
            steps {
                bat 'terraform plan -out=tfplan'
            }
        }

        stage('Package Lambda') {
            steps {
                bat 'powershell -Command "Compress-Archive -Path src\\index.js -DestinationPath lambda_function_payload.zip -Force"'
            }
        }

        stage('Terraform Apply') {
            steps {
                bat 'terraform apply -auto-approve tfplan'
            }
        }
    }
}
