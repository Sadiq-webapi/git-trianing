pipeline {
    agent any

    stages {
        stage("git-checkout") {
            steps {
                git branch: 'master', url: 'https://github.com/Sadiq-webapi/git-trianing.git'
            }
        }

        stage("build") {
            steps {
                bat'''
                echo "Building project..."
                printenv
                '''
            }
        }
 stage("docker-build") {
            steps {
                bat '''
                docker build -t myapp:latest .
                '''
            }
        }

        stage("docker-run") {
            steps {
               bat '''
                docker run -d -p 8080:80 myapp:latest
                '''
            }
        }
    }
}

