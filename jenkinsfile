pipeline {
    agent any

    stages {
        stage("git-checkout") {
            steps {
                git branch: 'master', url: 'https://github.com/Sadiq-webapi/git-trianing.git'
            }
        }

        stage("build") {
            steps {
                bat'''
                echo "Building project..."
                set
                '''
            }
        }
 stage("docker-build") {
            steps {
                bat '''
                docker build -t dockerfile .
                '''
            }
        }

        stage("docker") {
            steps {
               bat '''
                docker stop bb27a10c7539
                docker rm  bb27a10c7539
                docker run -d -p 9001:80 dockerfile
                '''
            }
        }
    }
}

