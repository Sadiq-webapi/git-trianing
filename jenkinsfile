pipeline {
    agent any

    stages {
        stage("git-checkout") {
            steps {
                git branch: 'master', url: 'https://github.com/Sadiq-webapi/git-trianing.git'
            }
        }

        stage("build") {
            steps {
                sh'''
                echo "Building project..."
                env
                '''
            }
        }
 stage("docker-build") {
            steps {
                sh'''
                docker build -t dockerfile .
                '''
            }
        }

      stage("docker") {
    steps {
        sh '''
        docker stop peaceful_torvalds || true
        docker rm peaceful_torvalds || true
        docker run -d --name peaceful_torvalds -p 9001:80 dockerfile
        '''
    }
}

    }
}

