pipeline {
    agent any

    stages {
        stage("git-checkout") {
            steps {
                git branch: 'master', url: 'https://github.com/Sadiq-webapi/git-trianing.git'
            }
        }

        stage("build") {
            steps {
                sh'''
                echo "Building project..."
                env
                '''
            }
        }
        
        stage("docker-build") {
            steps {
                sh '''
                docker build -t myapp:latest .
                '''
            }
        }

        stage("docker-run") {
            steps {
                sh '''
                docker run -d -p 9000:80 myapp:latest
                '''
            }
        }
    }
}
