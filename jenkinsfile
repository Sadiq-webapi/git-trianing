pipeline {
    agent any

    stages {
        stage("git-checkout") {
            steps {
                git branch: 'master', url: 'https://github.com/Sadiq-webapi/git-trianing.git'
            }
        }

        stage("build") {
            steps {
                sh '''
                echo "Building project..."
                env
                '''
            }
        }

        stage("docker-build") {
            steps {
                sh '''
                docker build -t mydockerhubuser/dockerfile:latest .
                '''
            }
        }

        stage("docker-run") {
            steps {
                sh '''
                docker run -d mongo:latest
                docker run -d -p 9000:80 mydockerhubuser/dockerfile:latest
                '''
            }
        }

        stage("docker-hub-login") {
            steps {
                withCredentials([usernamePassword(credentialsId: 'docker-hub-creds', passwordVariable: 'DOCKER_PASSWORD', usernameVariable: 'DOCKER_USERNAME')]) {
                    sh 'echo $DOCKER_PASSWORD | docker login -u $DOCKER_USERNAME --password-stdin'
                }
            }
        }

        stage("pushing-to-registry") {
            steps {
                sh '''
                docker push mydockerhubuser/dockerfile:latest
                '''
            }
        }
    }
}
