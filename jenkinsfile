pipeline {
    agent any

    stages {
        stage("git-checkout") {
            steps {
                git branch: 'main',   // or 'master' depending on your repo
                    url:'https://github.com/Sadiq-webapi/git-trianing.git',
                    credentialsId: 'github-ssh'
            }
        }

        stage("build") {
            steps {
                sh '''
                echo "Building project..."
                printenv
                '''
            }
        }
    }
}
