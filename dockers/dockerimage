pipeline {
    agent any
    environment {
        // FIXED: No slash at the end of the registry URL
        REGISTRY = "docker.io"
        REPO_NAME = "my-web-app"
    }

    stages {

        stage('Checkout') {
            steps {
                checkout scm
            }
        }

       stage('Build Image') {
    steps {
        // Use 'bat' for Windows, 'sh' for Linux
        bat "docker build -t 661268174324.dkr.ecr.ap-south-2.amazonaws.com/my-web-app:%BUILD_NUMBER% ."
    }
}

stage('Push to Docker Hub') {
    steps {
        // ID must match exactly what you saved in Manage Jenkins > Credentials
        withCredentials([usernamePassword(credentialsId: 'docker-hub-creds', 
                         usernameVariable: 'DOCKER_USER', 
                         passwordVariable: 'DOCKER_PASS')]) {
            bat """
            @echo off
            :: Use echo to pipe the password into docker login
            echo %DOCKER_PASS% | docker login -u %DOCKER_USER% --password-stdin
            
            :: Build with the full name from your screenshot
            docker build -t mohamedsadiq9741/myapp:%BUILD_NUMBER% .
            docker tag mohamedsadiq9741/myapp:%BUILD_NUMBER% mohamedsadiq9741/myapp:latest
            
            :: Push the image
            docker push mohamedsadiq9741/myapp:%BUILD_NUMBER%
            docker push mohamedsadiq9741/myapp:latest
            """
        }
    }
}
}
}
