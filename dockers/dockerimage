pipeline {
    agent any
    
    environment {
        // Change 'your-username' to your actual Docker Hub username
        DOCKER_IMAGE = "sadiq/nginx-app"
        DOCKER_TAG = "latest"
    }

    stages {

        stage('Checkout') {
            steps {
                checkout scm
            }
        }

       stage('Build Image') {
    steps {
        // Use 'bat' for Windows, 'sh' for Linux
        bat "docker build -t 661268174324.dkr.ecr.ap-south-2.amazonaws.com/my-web-app:%BUILD_NUMBER% ."
    }
}

stage('Push Image') {
    steps {
        // This block injects your keys into the session
        withCredentials([usernamePassword(credentialsId: 'aws-ecr-creds', 
                         usernameVariable: 'AWS_ACCESS_KEY_ID', 
                         passwordVariable: 'AWS_SECRET_ACCESS_KEY')]) {
            bat """
            @echo off
            :: Set the region for this session
            set AWS_DEFAULT_REGION=ap-south-2
            
            :: 1. Log in to ECR
            aws ecr get-login-password --region ap-south-2 | docker login --username AWS --password-stdin 661268174324.dkr.ecr.ap-south-2.amazonaws.com
            
            :: 2. Build and Push
            docker build -t 661268174324.dkr.ecr.ap-south-2.amazonaws.com/my-web-app:%BUILD_NUMBER% .
            docker push 661268174324.dkr.ecr.ap-south-2.amazonaws.com/my-web-app:%BUILD_NUMBER%
            """
        }
    }
}
}
}
