pipeline {
    agent any
    environment {
        // FIXED: No slash at the end of the registry URL
        REGISTRY = "docker.io"
        REPO_NAME = "my-web-app"
    }

    stages {

        stage('Checkout') {
            steps {
                checkout scm
            }
        }

       stage('Build Image') {
    steps {
        // Use 'bat' for Windows, 'sh' for Linux
        bat "docker build -t 661268174324.dkr.ecr.ap-south-2.amazonaws.com/my-web-app:%BUILD_NUMBER% ."
    }
}

stage('Push Image') {
    steps {
        // Use your Docker Hub credentials ID here
        withCredentials([usernamePassword(credentialsId: 'docker-hub-creds', 
                         usernameVariable: 'USER', 
                         passwordVariable: 'PASS')]) {
            bat """
            docker login -u %USER% -p %PASS%
            docker build -t %REPO_NAME%:%BUILD_NUMBER% .
            docker push %REPO_NAME%:%BUILD_NUMBER%
            """
        }
    }
}
}
}
