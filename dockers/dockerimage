pipeline {
    agent any
    
    environment {
        DOCKER_USER = "mohamedsadiq9741"
        REPO_NAME = "myapp"
        IMAGE_NAME = "${DOCKER_USER}/${REPO_NAME}"
    }

    stages {
        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Build & Push to Docker Hub') {
            steps {
                withCredentials([usernamePassword(credentialsId: 'docker-hub-creds', 
                                 usernameVariable: 'U', passwordVariable: 'P')]) {
                    bat """
                    @echo off
                    echo %P% | docker login -u %U% --password-stdin
                    docker build -t %IMAGE_NAME%:%BUILD_NUMBER% .
                    docker tag %IMAGE_NAME%:%BUILD_NUMBER% %IMAGE_NAME%:latest
                    docker push %IMAGE_NAME%:%BUILD_NUMBER%
                    docker push %IMAGE_NAME%:latest
                    """
                }
            }
        }

      stage('Deploy & Load Balancer') {
            steps {
                // Ensure 'aws-creds' matches your Jenkins Credentials ID
                withCredentials([usernamePassword(credentialsId: 'aws-creds', 
                                 usernameVariable: 'AWS_ACCESS_KEY_ID', 
                                 passwordVariable: 'AWS_SECRET_ACCESS_KEY')]) {
                    bat """
                    @echo off
                    :: 1. Authenticate with your EKS cluster
                    aws eks update-kubeconfig --region ap-south-2 --name web-app
                    
                    :: 2. Apply the Deployment and the Load Balancer Service
                    kubectl apply -f deployment.yaml
                    kubectl apply -f service.yaml
                    
                    :: 3. Update the deployment to use the specific build version
                    kubectl set image deployment/myapp-deployment myapp-container=mohamedsadiq9741/myapp:%BUILD_NUMBER%
                    """
                }
            }
        }
    }
}
