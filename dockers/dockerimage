pipeline {
    agent any
    
    environment {
        // Change 'your-username' to your actual Docker Hub username
        DOCKER_IMAGE = "sadiq/nginx-app"
        DOCKER_TAG = "latest"
    }

    stages {

        stage('Checkout') {
            steps {
                checkout scm
            }
        }

       stage('Build Image') {
    steps {
        // Use 'bat' for Windows, 'sh' for Linux
        bat "docker build -t 661268174324.dkr.ecr.ap-south-2.amazonaws.com/my-web-app:%BUILD_NUMBER% ."
    }
}

stage('Push Image') {
    steps {
        // Authenticate and push using standard AWS CLI and Docker commands
        bat """
        aws ecr get-login-password --region ap-south-2 | docker login --username AWS --password-stdin 661268174324.dkr.ecr.ap-south-2.amazonaws.com
        docker push 661268174324.dkr.ecr.ap-south-2.amazonaws.com/my-web-app:%BUILD_NUMBER%
        """
    }
}
}
}
